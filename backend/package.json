{
  "name": "innerspectrum-api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create innerspectrum_db",
    "db:migrate:local": "wrangler d1 execute innerspectrum_db --local --file=../sql/001_init.sql",
    "db:migrate:remote": "wrangler d1 execute innerspectrum_db --remote --file=../sql/001_init.sql",
    "db:migrate:email:local": "wrangler d1 execute innerspectrum_db --local --file=../sql/003_email_verification.sql",
    "db:migrate:email:remote": "wrangler d1 execute innerspectrum_db --remote --file=../sql/003_email_verification.sql",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250607.0",
    "typescript": "~5.8.2",
    "wrangler": "^4.19.1"
  }
}
